# ============================================================
# PANOPTIA -- Autonomous On-Chain AI Agent
# Environment Configuration
# ============================================================

# ----- Bot mode -----
# web   : launch REST + chat server (default)
# twitter : run Twitter reply bot
BOT_MODE=web

# ----- xAI / Grok -----
XAI_API_KEY=xai-...
AI_MODEL_NAME=grok-3
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=800

# ----- Solana -----
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
AGENT_WALLET_PUBLIC=DbzFutGThzbMNaDyqvdzWugdZuhnaqtWyfD9qp9GZRRV

# ----- GitHub crawler (optional but recommended) -----
# Raises API rate limit from 60 to 5000 requests/hour
GITHUB_TOKEN=ghp_...

# ----- Web server -----
WEB_PORT=3000
WEB_ENABLE_CORS=true
# WEB_API_KEY=your_secret_api_key

# ----- Twitter (only needed for BOT_MODE=twitter) -----
# Get keys at https://developer.twitter.com
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_AUTO_REPLY=true